# Deployment handoff - the frontend dev tool (`just dev-anvil` in ../frontend)
# upserts these on every deploy, so the index always follows the newest contract:
# ENVIO_DELIBERATE_ADDRESS=0x...            # the Deliberate deployment to index
# ENVIO_PIN_IPFS_API=http://127.0.0.1:5001 # kubo-compatible API for the pinning backstop

# HyperSync API token - only needed for public chains, not for local RPC sync.
# To create or update a token visit https://envio.dev/app/api-tokens
# ENVIO_API_TOKEN="<YOUR-API-TOKEN>"
